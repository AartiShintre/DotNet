@model List<StudentApp.Models.Student>

<h2>Student List</h2>

<a href="/Student/Create">Add Student</a>

<table border="1">
    <tr>
        <th>Name</th>
        <th>Marks</th>
        <th>Email</th>
    </tr>

@foreach (var s in Model)
{
    <tr>
        <td>@s.Name</td>
        <td>@s.Marks</td>
        <td>@s.Email</td>
    </tr>
}
</table>